{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["node", "express"],
    "paths": {
      "@warung-bujo/database": ["../../packages/database"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
